---
// Layout base: HTML, metas, transiciones y utilidades globales.
//import { ViewTransitions } from "astro:transitions";

const { title = "mvp-peach-six.vercel.app" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Marca transiciones al volver del perfil -->
    <script>
      try {
        if (sessionStorage.getItem("ab_profile_enter") === "1") {
          document.documentElement.classList.add("ab-profile-enter");
        }
      } catch {
        // ignore
      }
    </script>
    <title>{title}</title>
    <!-- <ViewTransitions fallback="animate" /> -->
  </head>
  <body>
    <slot />
    <!-- Script global: transiciones y prefetch interno -->
    <script>
      const PROFILE_ENTER_KEY = "ab_profile_enter";

      /* Detecta clicks que van al perfil para animación de entrada. */
      const markProfileEnter = (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const link = target.closest("[data-ab-profile-link]");
        if (link) {
          try {
            sessionStorage.setItem(PROFILE_ENTER_KEY, "1");
          } catch {
            // ignore
          }
        }
      };

      document.addEventListener("click", markProfileEnter);

      /* Limpia la clase luego de la animación. */
      try {
        if (sessionStorage.getItem(PROFILE_ENTER_KEY) === "1") {
          sessionStorage.removeItem(PROFILE_ENTER_KEY);
          window.setTimeout(() => {
            document.documentElement.classList.remove("ab-profile-enter");
          }, 280);
        }
      } catch {
        // ignore
      }

      /* Determina si un link es interno (para prefetch). */
      const isInternalLink = (link) => {
        const href = link.getAttribute("href");
        if (!href) return false;
        if (href.startsWith("http") || href.startsWith("mailto:") || href.startsWith("tel:")) {
          return false;
        }
        if (href.startsWith("#")) return false;
        return true;
      };

      /* Habilita prefetch en hover para navegación interna. */
      document.querySelectorAll("a[href]").forEach((link) => {
        if (isInternalLink(link)) {
          link.setAttribute("data-astro-prefetch", "hover");
        }
      });
    </script>
  </body>
</html>
