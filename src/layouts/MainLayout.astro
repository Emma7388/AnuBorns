---
// Layout principal: header, footer y navegación de regreso.
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

// Calcula el "volver" según ruta.
const { title, backHref: customBackHref } = Astro.props;
const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const backHref = customBackHref ?? (segments.length <= 1 ? "/" : `/${segments.slice(0, -1).join("/")}`);
const showBack = pathname !== "/";
---

<BaseLayout title={title}>
  <!-- Header global -->
  <Header />

  <!-- Contenido de página -->
  <main data-ab-page-title={title ?? ""}>
    <slot />
  </main>

  <!-- Footer con CTA volver -->
  <Footer showBack={showBack} backHref={backHref} />

  <!-- Intercepta botón volver cuando se pide volver por history -->
  <script is:inline>
    const bindBackLinks = () => {
      const backLinks = document.querySelectorAll("[data-ab-back]");
      if (backLinks.length && window.history.length > 1) {
        backLinks.forEach((link) => {
          if (link.getAttribute("data-ab-back") !== "history") return;
          if (link.dataset.abBackBound === "true") return;
          link.addEventListener("click", (event) => {
            event.preventDefault();
            window.history.back();
          });
          link.dataset.abBackBound = "true";
        });
      }
    };

    const mountHeaderTitle = () => {
      const headerTitle = document.getElementById("ab-header-page-title");
      const main = document.querySelector("main");
      if (!headerTitle || !main) return;

      headerTitle.innerHTML = "";
      const firstH1 = main.querySelector("h1");
      if (firstH1) {
        headerTitle.appendChild(firstH1);
        return;
      }

      const fallbackTitle = (main.dataset.abPageTitle || "").trim();
      if (!fallbackTitle) return;
      const h1 = document.createElement("h1");
      h1.textContent = fallbackTitle;
      headerTitle.appendChild(h1);
    };

    const runLayoutEnhancements = () => {
      bindBackLinks();
      mountHeaderTitle();
    };

    runLayoutEnhancements();

    if (!window.__abLayoutEnhancementsBound) {
      document.addEventListener("astro:page-load", runLayoutEnhancements);
      document.addEventListener("astro:after-swap", runLayoutEnhancements);
      document.addEventListener("astro:before-swap", () => {
        const headerTitle = document.getElementById("ab-header-page-title");
        if (headerTitle) headerTitle.innerHTML = "";
      });
      window.addEventListener("pageshow", runLayoutEnhancements);
      window.__abLayoutEnhancementsBound = true;
    }
  </script>
</BaseLayout>
