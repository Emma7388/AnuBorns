---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const { title, backHref: customBackHref } = Astro.props;
const pathname = Astro.url.pathname;
const segments = pathname.split("/").filter(Boolean);
const backHref = customBackHref ?? (segments.length <= 1 ? "/" : `/${segments.slice(0, -1).join("/")}`);
const showBack = pathname !== "/";
---

<BaseLayout title={title}>
  <Header />

  <main>
    {showBack && (
      <div class="ab-desktop-back">
        <a class="ab-back-link" href={backHref} data-ab-back>Volver</a>
      </div>
    )}
    <slot />
  </main>

  <Footer showBack={showBack} />

  <script is:inline>
    const backLinks = document.querySelectorAll("[data-ab-back]");
    if (backLinks.length && window.history.length > 1) {
      backLinks.forEach((link) => {
        link.addEventListener("click", (event) => {
          event.preventDefault();
          window.history.back();
        });
      });
    }
  </script>
</BaseLayout>
