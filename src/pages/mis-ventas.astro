---
// Página: ventas del usuario (MVP local + productos propios).
import MainLayout from "../layouts/MainLayout.astro";
// URL del script de ventas (cliente).
import salesScriptUrl from "../scripts/mis-ventas.js?url";
---

<MainLayout title="Mis ventas" backHref="/mis-datos">
  <!-- Panel principal -->
  <section class="ab-dark-panel ab-orders-panel">
    <p class="ab-eyebrow"></p>
    <h1>Mis ventas</h1>
    <p class="ab-muted-text"></p>

    <!-- Productos vendidos -->
    <h2>Productos vendidos</h2>
    <p id="my-sold-products-status" class="ab-muted-text"></p>
    <div id="my-sold-products-list" class="ab-orders-list"></div>
    <div id="my-sold-products-empty" class="ab-cart-empty ab-is-hidden">
      <p>Todavía no tenés productos vendidos.</p>
    </div>

    <!-- Productos publicados -->
    <h2>Productos publicados</h2>
    <div id="my-products-grid" class="ab-provider-products-grid"></div>
    <div id="my-products-empty" class="ab-cart-empty ab-is-hidden">
      <p>Todavía no publicaste productos.</p>
    </div>

    <!-- Sección de ventas (MVP) -->
    <div id="sale-active" class="ab-is-hidden"></div>
    <div id="sales-empty" class="ab-cart-empty ab-is-hidden">
      <p>Aún no tenés ventas registradas.</p>
    </div>
    <h2 id="sales-history-title" class="ab-is-hidden"></h2>
    <div class="ab-actions ab-is-hidden"></div>
    <div id="sales-list" class="ab-orders-list ab-is-hidden"></div>
  </section>

  <!-- Modal de confirmación para borrar producto publicado -->
  <div
    id="sales-delete-modal"
    class="ab-orders-modal ab-is-hidden"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="sales-delete-title"
  >
    <div class="ab-orders-modal__backdrop" data-sales-modal-close></div>
    <div class="ab-orders-modal__panel" role="document">
      <h2 id="sales-delete-title">Borrar producto</h2>
      <p>¿Seguro que querés borrar este producto publicado?</p>
      <div class="ab-orders-modal__actions">
        <button type="button" class="ab-orders-delete-btn ab-orders-delete-btn--ghost" data-sales-modal-cancel>
          Cancelar
        </button>
        <button type="button" class="ab-orders-delete-btn" data-sales-modal-confirm>
          Sí, borrar
        </button>
      </div>
    </div>
  </div>
</MainLayout>

<script type="module" src={salesScriptUrl}></script>

<script type="module">
  // MVP local: seed y render de ventas.
  const SALES_KEY = "ab_sales_v1";
  const activeContainer = document.getElementById("sale-active");
  const list = document.getElementById("sales-list");
  const emptyState = document.getElementById("sales-empty");
  const historyTitle = document.getElementById("sales-history-title");
  const resetButton = document.getElementById("sales-reset");
  const productsGrid = document.getElementById("my-products-grid");
  const productsEmpty = document.getElementById("my-products-empty");

  // Seed de ventas de ejemplo.
  const seedSales = {
    active: {
      id: "VE-2309",
      date: "18 Mar 2026",
      total: 98000,
      status: "Esperando retiro",
      delivery: "Retiro en local - 19 Mar 2026",
      customer: "Carlos Vega",
      items: [
        { name: "Martillo de acero 16oz", qty: 1, price: 22000 },
        { name: "Kit tornillos", qty: 3, price: 6000 },
      ],
    },
    history: [
      {
        id: "VE-2251",
        date: "07 Mar 2026",
        total: 45500,
        items: [
          { name: "Sierra circular", qty: 1, price: 45500, customer: "Lucia Peralta" },
        ],
      },
      {
        id: "VE-2219",
        date: "19 Feb 2026",
        total: 31000,
        items: [
          { name: "Caja herramientas", qty: 1, price: 31000, customer: "Diego Suárez" },
        ],
      },
    ],
  };

  // Normaliza estructuras antiguas.
  const normalizeSales = (data) => {
    if (Array.isArray(data)) {
      return { active: null, history: data };
    }
    if (data && typeof data === "object") {
      return {
        active: data.active ?? null,
        history: Array.isArray(data.history) ? data.history : [],
      };
    }
    return seedSales;
  };

  // Persiste en localStorage.
  const persistSales = (value) => {
    window.localStorage.setItem(SALES_KEY, JSON.stringify(value));
  };

  // Lee storage o inicializa seed.
  const loadSales = () => {
    try {
      const raw = window.localStorage.getItem(SALES_KEY);
      if (!raw) {
        persistSales(seedSales);
        return seedSales;
      }
      const parsed = JSON.parse(raw);
      const normalized = normalizeSales(parsed);
      if (Array.isArray(parsed) || parsed?.history === undefined || parsed?.active === undefined) {
        persistSales(normalized);
      }
      return normalized;
    } catch {
      return seedSales;
    }
  };

  // Formatea precios ARS.
  const formatPrice = (value) => {
    const safe = Number(value ?? 0);
    return safe.toLocaleString("es-AR");
  };

  // Render de venta activa.
  const renderActive = (active) => {
    if (!active) {
      activeContainer.innerHTML = "";
      return;
    }

    const items = Array.isArray(active.items) ? active.items : [];
    activeContainer.innerHTML = `
      <article class="ab-order-card ab-order-card--active">
        <div class="ab-order-card__header">
          <div>
            <p class="ab-order-card__label">Venta ${active.id ?? ""}</p>
            <p class="ab-order-card__date">${active.date ?? ""}</p>
          </div>
          <div class="ab-order-card__header-actions">
            <strong>$${formatPrice(active.total ?? 0)}</strong>
            <span class="ab-order-card__status ab-order-card__status--active">
              ${active.status ?? "En curso"}
            </span>
          </div>
        </div>
        <div class="ab-order-card__details">
          <p>Cliente: ${active.customer ?? "Pendiente"}</p>
          <p>Entrega: ${active.delivery ?? "Por confirmar"}</p>
        </div>
        <ul class="ab-order-card__items">
          ${items
            .map((item) => {
              const qty = item.qty ?? 1;
              const price = Number(item.price ?? 0);
              return `
                <li>
                  <div>
                    <strong>${item.name} x ${qty}</strong>
                  </div>
                  <span>$${formatPrice(price * qty)}</span>
                </li>
              `;
            })
            .join("")}
        </ul>
        <div class="ab-actions">
          <a
            class="ab-cta-button"
            href="https://wa.me/5491137915210"
            target="_blank"
            rel="noreferrer"
          >
            Contactar (MVP)
          </a>
        </div>
      </article>
    `;
  };

  // Render de historial de ventas.
  const renderHistory = (history) => {
    list.innerHTML = "";

    if (!Array.isArray(history) || history.length === 0) {
      historyTitle.style.display = "none";
      return;
    }

    historyTitle.style.display = "";

    history.forEach((sale) => {
      const wrapper = document.createElement("article");
      wrapper.className = "ab-order-card";
      const items = Array.isArray(sale.items) ? sale.items : [];
      wrapper.innerHTML = `
        <div class="ab-order-card__header">
          <div>
            <p class="ab-order-card__label">Venta ${sale.id ?? ""}</p>
            <p class="ab-order-card__date">${sale.date ?? ""}</p>
          </div>
          <strong>$${formatPrice(sale.total ?? 0)}</strong>
        </div>
        <ul class="ab-order-card__items">
          ${items
            .map((item) => {
              const qty = item.qty ?? 1;
              const price = Number(item.price ?? 0);
              const customer = item.customer ?? "N/A";
              return `
                <li>
                  <div>
                    <strong>${item.name} x ${qty}</strong>
                    <p>Cliente: ${customer}</p>
                  </div>
                  <span>$${formatPrice(price * qty)}</span>
                </li>
              `;
            })
            .join("")}
        </ul>
      `;
      list.appendChild(wrapper);
    });
  };

  // Render total de ventas.
  const renderSales = () => {
    const data = loadSales();
    const active = data?.active ?? null;
    const history = data?.history ?? [];

    renderActive(active);
    renderHistory(history);

    const hasActive = Boolean(active);
    const hasHistory = Array.isArray(history) && history.length > 0;
    if (hasActive || hasHistory) {
      emptyState.classList.add("ab-is-hidden");
      emptyState.style.display = "none";
      return;
    }
    emptyState.classList.remove("ab-is-hidden");
    emptyState.style.display = "grid";
  };

  // Inicialización.
  renderSales();
  // products grid handled in src/scripts/mis-ventas.js

  resetButton?.addEventListener("click", () => {
    persistSales(seedSales);
    renderSales();
  });
</script>
