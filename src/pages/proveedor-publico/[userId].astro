---
// Página pública de proveedor por user_id.
export const prerender = false;

import MainLayout from "../../layouts/MainLayout.astro";

const { userId } = Astro.params;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const safeUserId = encodeURIComponent(userId ?? "");

const fetchJson = async (url) => {
  const response = await fetch(url, {
    headers: {
      apikey: supabaseAnonKey,
      Authorization: `Bearer ${supabaseAnonKey}`,
      "Cache-Control": "no-store",
    },
    cache: "no-store",
  });
  if (!response.ok) return null;
  return response.json();
};

const products = supabaseUrl && supabaseAnonKey && safeUserId
  ? await fetchJson(
      `${supabaseUrl}/rest/v1/products?select=id,title,description,price,currency,image_url,location,delivery_methods,pickup_address,contact,seller_name,user_id,created_at&user_id=eq.${safeUserId}&order=created_at.desc`
    )
  : [];

const safeProducts = Array.isArray(products) ? products : [];
const first = safeProducts[0] ?? null;

const sellerName = first?.seller_name || "Proveedor";
const rawContact = String(first?.contact ?? "").trim();
const emailMatch = rawContact.match(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}/i);
const publicEmail = emailMatch?.[0] ?? "";
const phoneDigits = rawContact.replace(/\D+/g, "");
const publicPhone = phoneDigits ? rawContact : "";
const publicAddress = String(first?.pickup_address ?? "").trim();
const publicLocation = String(first?.location ?? "").trim();

const formatPrice = (value) => {
  const safe = Number(value ?? 0);
  return safe.toLocaleString("es-AR");
};
const formatDate = (value) => {
  if (!value) return "Sin fecha";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return "Sin fecha";
  return date.toLocaleDateString("es-AR", { day: "2-digit", month: "short", year: "numeric" });
};
const formatDelivery = (value) => {
  if (!Array.isArray(value) || value.length === 0) return "No especificada";
  const labels = value.map((item) => {
    if (item === "retiro") return "Retiro";
    if (item === "envio") return "Envío";
    return item;
  });
  return labels.join(" + ");
};
const shortId = (value) => {
  const raw = String(value ?? "").replace(/-/g, "");
  return raw ? raw.slice(0, 6).toUpperCase() : "N/A";
};
---

<MainLayout title={`Proveedor: ${sellerName}`} backHref="history">
  {first ? (
    <section class="ab-dark-panel">
      <p class="ab-eyebrow">Perfil público</p>
      <h1>{sellerName}</h1>
      <p class="ab-muted-text">Datos públicos del proveedor.</p>

      <div class="ab-provider-profile__meta">
        <p>
          <strong>Teléfono:</strong>{" "}
          {publicPhone ? (
            <a
              href={`https://wa.me/${phoneDigits}?text=${encodeURIComponent(`Hola ${sellerName}, te contacto por AnuBorns.`)}`}
              target="_blank"
              rel="noreferrer noopener"
            >
              {publicPhone}
            </a>
          ) : "No publicado"}
        </p>
        <p><strong>Email:</strong> {publicEmail || "No publicado"}</p>
        <p><strong>Dirección:</strong> {publicAddress || "No publicada"}</p>
        <p><strong>Ubicación:</strong> {publicLocation || "No publicada"}</p>
      </div>

      <h2>Productos publicados</h2>
      {safeProducts.length === 0 ? (
        <div class="ab-cart-empty">
          <p>Este proveedor todavía no publicó productos.</p>
        </div>
      ) : (
        <div class="ab-provider-products-grid">
          {safeProducts.map((product) => (
            <article
              class="ab-provider-product-card"
              data-user-id={product.user_id || ""}
              data-title={product.title || ""}
              data-price={product.price ?? 0}
              data-image={product.image_url || "/logo2.svg"}
              data-provider={product.seller_name || sellerName || "Vendedor"}
              data-cart-id={product.id || ""}
            >
              <img
                class="ab-provider-product-card__image"
                src={product.image_url || "/logo2.svg"}
                alt={product.title || "Producto"}
                loading="lazy"
              />
              <div class="ab-provider-product-card__meta">
                <div>
                  <p class="ab-provider-product-card__label">Producto</p>
                  <p class="ab-provider-product-card__code">ID {shortId(product.id)}</p>
                </div>
                <p class="ab-provider-product-card__price">
                  ${formatPrice(product.price)} <span>{product.currency || "ARS"}</span>
                </p>
              </div>
              <h2>{product.title || "Sin título"}</h2>
              <p class="ab-provider-product-card__description">{product.description || "Sin descripción"}</p>
              <ul class="ab-provider-product-card__details">
                <li>Publicada el <strong>{formatDate(product.created_at)}</strong></li>
                <li>Ubicación: <strong>{product.location || "Sin especificar"}</strong></li>
                {product.pickup_address ? (
                  <li>Dirección: <strong>{product.pickup_address}</strong></li>
                ) : null}
                <li>Entrega: <strong>{formatDelivery(product.delivery_methods)}</strong></li>
              </ul>
              <button
                type="button"
                class="ab-provider-product-card__add"
                aria-label="Agregar al carrito"
                title="Agregar al carrito"
              >
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path
                    d="M7 18a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm10 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM6.2 6l.7 3.2h11.7a1 1 0 0 1 1 .8l-1.1 5a1 1 0 0 1-1 .8H8.2a1 1 0 0 1-1-.8L5.1 5H3a1 1 0 1 1 0-2h2.9a1 1 0 0 1 1 .8L7.1 4H20a1 1 0 1 1 0 2H6.2z"
                    fill="currentColor"
                  ></path>
                </svg>
              </button>
            </article>
          ))}
        </div>
      )}
    </section>
  ) : (
    <section class="ab-dark-panel">
      <h1>Proveedor no encontrado</h1>
      <p>Este proveedor no tiene datos públicos cargados todavía.</p>
    </section>
  )}
</MainLayout>

<script>
  import "../../scripts/comprar-productos.js";
</script>
