---
import MainLayout from "../../layouts/MainLayout.astro";
import { providers } from "../../data/providers";

export async function getStaticPaths() {
  return providers.map((provider) => ({
    params: { slug: provider.slug },
  }));
}

const { slug } = Astro.params;
const provider = providers.find((item) => item.slug === slug);
---

<MainLayout title={provider ? `Proveedor: ${provider.name}` : "Proveedor"}>
  {provider ? (
    <section class="provider-profile">
      <header class="provider-header">
        <h1>{provider.name}</h1>
        <p class="location">{provider.location}</p>
      </header>

      <div class="provider-meta">
        <p><strong>Ranking:</strong> #{provider.ranking}</p>
        <p><strong>Promedio publicado:</strong> ${provider.average}</p>
        <p><strong>Categoría:</strong> {provider.category}</p>
        {provider.sponsor && <p class="sponsor">Proveedor sponsor</p>}
      </div>

      <button class="hire-btn">Iniciar contratación</button>
    </section>
  ) : (
    <section class="provider-profile">
      <h1>Proveedor no encontrado</h1>
      <p>Verificá el enlace o volvé al listado de categorías.</p>
    </section>
  )}
</MainLayout>

<style>
  .provider-profile {
    max-width: 760px;
    margin: 40px auto;
    padding: 28px;
    background: #11161C;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: #ffffff;
  }

  .provider-header h1 {
    margin-bottom: 6px;
  }

  .location {
    color: rgba(255, 255, 255, 0.7);
  }

  .provider-meta {
    margin: 28px 0;
    display: grid;
    gap: 10px;
  }

  .sponsor {
    color: #16C784;
    font-weight: 700;
  }

  .hire-btn {
    background: #16C784;
    color: #0B0F14;
    border: none;
    border-radius: 12px;
    padding: 12px 18px;
    font-weight: 700;
    cursor: pointer;
  }

  .hire-btn:hover {
    box-shadow: 0 10px 25px rgba(22, 199, 132, 0.4);
  }
</style>