---
import MainLayout from "../layouts/MainLayout.astro";
import checkoutScriptUrl from "../scripts/checkout.js?url";
---

<MainLayout title="Finalizar compra">
  <section class="ab-dark-panel ab-checkout-panel">
    <p class="ab-eyebrow">Checkout</p>
    <h1>Finalizar compra</h1>
    <p class="ab-muted-text">
      Confirmá tus datos y continuá el pago con Mercado Pago.
    </p>

    <div id="checkout-empty" class="ab-cart-empty">
      <p>No hay productos para finalizar.</p>
    </div>

    <div id="checkout-summary" class="ab-checkout-summary">
      <h2>Resumen</h2>
      <div id="checkout-items" class="ab-checkout-items"></div>
      <p class="ab-checkout-total">
        Total: <strong id="checkout-total">$0</strong>
      </p>
    </div>

    <form id="checkout-form" class="ab-form ab-checkout-form">
      <h2>Datos de entrega</h2>
      <label for="full-name">Nombre completo</label>
      <input id="full-name" name="full-name" type="text" placeholder="Ej: Maria Lopez" required />

      <label for="address">Dirección</label>
      <input id="address" name="address" type="text" placeholder="Ej: Av. Siempreviva 742" required />

      <label for="city">Ciudad</label>
      <input id="city" name="city" type="text" placeholder="Ej: Rosario" required />

      <label for="phone">Telefono</label>
      <input id="phone" name="phone" type="tel" placeholder="Ej: 341 555 1234" required />

      <button class="ab-cta-button" type="submit">
        Pagar con Mercado Pago
      </button>
      <p id="checkout-feedback" class="ab-muted-text" aria-live="polite"></p>
    </form>
  </section>
</MainLayout>

<script type="module" src={checkoutScriptUrl}></script>
