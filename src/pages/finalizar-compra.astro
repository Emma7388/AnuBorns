---
// Página: checkout y datos de entrega.
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Finalizar compra">
  <!-- Panel principal de checkout -->
  <section class="ab-dark-panel ab-checkout-panel">
    <p class="ab-eyebrow">Checkout</p>
    <h1>Finalizar compra</h1>
    <p class="ab-muted-text">
      Confirmá tus datos y continuá el pago con Mercado Pago.
    </p>

    <!-- Estado vacío -->
    <div id="checkout-empty" class="ab-cart-empty">
      <p>No hay productos para finalizar.</p>
    </div>

    <!-- Resumen del pedido -->
    <div id="checkout-summary" class="ab-checkout-summary">
      <h2>Resumen</h2>
      <div id="checkout-items" class="ab-checkout-items"></div>
      <p class="ab-checkout-total">
        Total: <strong id="checkout-total">$0</strong>
      </p>
    </div>

    <!-- Formulario de entrega -->
    <form id="checkout-form" class="ab-form ab-checkout-form">
      <h2>Datos de entrega</h2>
      <label for="full-name">Nombre completo</label>
      <input id="full-name" name="full-name" type="text" placeholder="Ej: Maria Lopez" required />

      <label for="email">Email (opcional)</label>
      <input id="email" name="email" type="email" placeholder="Ej: maria@email.com" />

      <label for="phone">Telefono</label>
      <input id="phone" name="phone" type="tel" placeholder="Ej: 341 555 1234" required />

      <label for="notes">Nota/Comentario (opcional)</label>
      <textarea id="notes" name="notes" rows="3" placeholder="Ej: Dejar en porteria por la tarde."></textarea>

      <button class="ab-cta-button" type="submit">
        FINALIZAR COMPRA
      </button>
      <p id="checkout-feedback" class="ab-muted-text" aria-live="polite"></p>
    </form>

    <!-- Mensaje de éxito -->
    <div id="checkout-success" class="ab-checkout-success ab-is-hidden" aria-live="polite">
      <div class="ab-checkout-success__icon">✓</div>
      <p>Pago iniciado. Te estamos redirigiendo…</p>
    </div>
  </section>

  <div
    id="checkout-confirm-modal"
    class="ab-orders-modal ab-is-hidden"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="checkout-confirm-title"
  >
    <div class="ab-orders-modal__backdrop" data-checkout-modal-close></div>
    <div class="ab-orders-modal__panel" role="document">
      <h2 id="checkout-confirm-title">Confirmar compra</h2>
      <p>¿Querés finalizar la compra y continuar al pago?</p>
      <div class="ab-orders-modal__actions">
        <button type="button" class="ab-orders-delete-btn ab-orders-delete-btn--ghost" data-checkout-modal-cancel>
          Cancelar
        </button>
        <button type="button" class="ab-orders-delete-btn" data-checkout-modal-confirm>
          Sí, finalizar
        </button>
      </div>
    </div>
  </div>
</MainLayout>

<!-- Script de checkout -->
<script>
  import "../scripts/checkout.js";
</script>
