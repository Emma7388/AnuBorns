---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Finalizar compra">
  <section class="ab-dark-panel ab-checkout-panel">
    <p class="ab-eyebrow">Compra simulada</p>
    <h1>Finalizar compra</h1>
    <p class="ab-muted-text">
      Esta pantalla completa el flujo con un formulario ficticio.
    </p>

    <div id="checkout-empty" class="ab-cart-empty">
      <p>No hay productos para finalizar.</p>
      <a class="ab-back-link" href="/comprar/productos">Volver a comprar</a>
    </div>

    <div id="checkout-summary" class="ab-checkout-summary">
      <h2>Resumen</h2>
      <div id="checkout-items" class="ab-checkout-items"></div>
      <p class="ab-checkout-total">
        Total: <strong id="checkout-total">$0</strong>
      </p>
    </div>

    <form id="checkout-form" class="ab-form ab-checkout-form">
      <h2>Datos de entrega</h2>
      <label for="full-name">Nombre completo</label>
      <input id="full-name" name="full-name" type="text" placeholder="Ej: Maria Lopez" required />

      <label for="address">Dirección</label>
      <input id="address" name="address" type="text" placeholder="Ej: Av. Siempreviva 742" required />

      <label for="city">Ciudad</label>
      <input id="city" name="city" type="text" placeholder="Ej: Rosario" required />

      <label for="phone">Telefono</label>
      <input id="phone" name="phone" type="tel" placeholder="Ej: 341 555 1234" required />

      <h2>Pago (simulado)</h2>
      <label for="card-number">Numero de tarjeta</label>
      <input id="card-number" name="card-number" type="text" placeholder="0000 0000 0000 0000" required />

      <div class="ab-checkout-row">
        <div>
          <label for="card-exp">Vencimiento</label>
          <input id="card-exp" name="card-exp" type="text" placeholder="MM/AA" required />
        </div>
        <div>
          <label for="card-cvv">CVV</label>
          <input id="card-cvv" name="card-cvv" type="text" placeholder="123" required />
        </div>
      </div>

      <button class="ab-cta-button" type="submit">
        Confirmar compra (MVP)
      </button>
      <p id="checkout-feedback" class="ab-muted-text" aria-live="polite"></p>
    </form>
  </section>
</MainLayout>

<script>
  const CART_KEY = "ab_cart_v1";
  const emptyState = document.getElementById("checkout-empty");
  const summary = document.getElementById("checkout-summary");
  const itemsWrap = document.getElementById("checkout-items");
  const totalLabel = document.getElementById("checkout-total");
  const form = document.getElementById("checkout-form");
  const feedback = document.getElementById("checkout-feedback");

  const loadCart = () => {
    try {
      const raw = window.localStorage.getItem(CART_KEY);
      const parsed = raw ? JSON.parse(raw) : [];
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return [];
    }
  };

  const formatPrice = (value) => {
    const safe = Number(value ?? 0);
    return safe.toLocaleString("es-AR");
  };

  const renderSummary = () => {
    const items = loadCart();
    itemsWrap.innerHTML = "";

    if (items.length === 0) {
      emptyState.style.display = "grid";
      summary.style.display = "none";
      form.style.display = "none";
      totalLabel.textContent = "$0";
      return;
    }

    emptyState.style.display = "none";
    summary.style.display = "grid";
    form.style.display = "grid";

    let total = 0;
    items.forEach((item) => {
      const qty = item.qty ?? 1;
      const price = Number(item.price ?? 0);
      total += price * qty;

      const row = document.createElement("div");
      row.className = "ab-checkout-item";
      row.innerHTML = `
        <span>${item.name} x ${qty}</span>
        <strong>$${formatPrice(price * qty)}</strong>
      `;
      itemsWrap.appendChild(row);
    });

    totalLabel.textContent = `$${formatPrice(total)}`;
  };

  if (form && feedback) {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      feedback.textContent = "Procesando compra simulada...";
      window.setTimeout(() => {
        window.location.href = "/compra-confirmada";
      }, 600);
    });
  }

  renderSummary();
</script>
