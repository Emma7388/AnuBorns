---
// Página: flujo de contratación de proveedor.
import MainLayout from "../../layouts/MainLayout.astro";
import { providers } from "../../data/providers";
import { categories } from "../../data/categories";

// Resolución de proveedor y back link.
const { slug } = Astro.params;
const provider = providers.find((item) => item.slug === slug);
const categoryName = categories.find((item) => item.slug === provider?.category)?.name;
const fromParam = Astro.url.searchParams.get("from");
const backHref = fromParam && fromParam.startsWith("/")
  ? fromParam
  : provider
    ? `/proveedor/${provider.slug}`
    : "/comprar/productos";
---

<MainLayout title={provider ? `Contratar a ${provider.name}` : "Contratación"} backHref={backHref}>
  {provider ? (
    <!-- Panel de contratación -->
    <section class="ab-dark-panel">
      <p class="ab-eyebrow">Solicitud de contratación</p>
      <h1>{provider.name}</h1>
      <p class="ab-contract__subtitle">
        Categoría: <strong>{categoryName ?? provider.category}</strong> · {provider.location}
      </p>

      <!-- Pasos del proceso -->
      <div class="ab-contract__steps">
        <h2>Cómo sigue el proceso</h2>
        <ol>
          <li>Completás tu solicitud con detalles del trabajo.</li>
          <li>El profesional acepta o rechaza la solicitud.</li>
          <li>Si acepta, avanzás al pago y confirmación final.</li>
        </ol>
      </div>

      <!-- Formulario de solicitud -->
      <form class="ab-contract__form">
        <label for="job-description">Descripción del trabajo</label>
        <textarea
          id="job-description"
          name="job-description"
          rows="5"
          placeholder="Ej: Necesito cambiar la instalación de agua de la cocina y revisar una pérdida en baño."
        ></textarea>

        <label for="preferred-date">Fecha estimada</label>
        <input id="preferred-date" name="preferred-date" type="date" />

        <button class="ab-cta-button" type="button">Enviar solicitud (MVP)</button>
      </form>

    </section>
  ) : (
    <!-- Fallback cuando no existe el proveedor -->
    <section class="ab-dark-panel">
      <h1>Proveedor no encontrado</h1>
      <p>La contratación no puede iniciarse porque el proveedor no existe.</p>
    </section>
  )}
</MainLayout>
