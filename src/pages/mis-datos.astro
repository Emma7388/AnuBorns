---
// Página: perfil del usuario.
import MainLayout from "../layouts/MainLayout.astro";
import profileScriptUrl from "../scripts/profile.js?url";
---

<MainLayout title="Mis datos">
  <!-- Panel de perfil -->
  <section class="ab-dark-panel ab-profile-data">
    <p class="ab-eyebrow">Perfil</p>
    <!-- Avatar -->
    <div class="ab-profile-avatar">
      <img id="profile-avatar" alt="Avatar" />
    </div>
    <!-- Estado de carga -->
    <p class="ab-muted-text" id="profile-status">
      Cargando información del usuario...
    </p>

    <!-- Form de avatar -->
    <form class="ab-form" id="avatar-form">
      <label for="avatar-upload">Actualizar avatar</label>
      <input id="avatar-upload" name="avatar-upload" type="file" accept="image/*" />
      <p class="ab-muted-text" id="avatar-feedback" aria-live="polite"></p>
    </form>

    <!-- CTA de edición -->
    <div class="ab-actions">
      <button type="button" class="ab-cta-button" id="profile-edit-toggle">
        Editar perfil
      </button>
    </div>

    <!-- Form de datos del perfil -->
    <form class="ab-form" id="profile-form">
      <label for="profile-email">Email</label>
      <input id="profile-email" name="profile-email" type="email" readonly />

      <label for="profile-first-name">Nombre</label>
      <input id="profile-first-name" name="profile-first-name" type="text" />

      <label for="profile-last-name">Apellido</label>
      <input id="profile-last-name" name="profile-last-name" type="text" />

      <label for="profile-phone">Teléfono</label>
      <input id="profile-phone" name="profile-phone" type="tel" />

      <label for="profile-dni">DNI</label>
      <input id="profile-dni" name="profile-dni" type="text" />

      <label for="profile-address">Dirección</label>
      <input id="profile-address" name="profile-address" type="text" />

      <label for="profile-city">Ciudad</label>
      <input id="profile-city" name="profile-city" type="text" />

      <label for="profile-province">Provincia</label>
      <input id="profile-province" name="profile-province" type="text" />

      <label for="profile-postal-code">Código postal</label>
      <input id="profile-postal-code" name="profile-postal-code" type="text" />

      <button type="submit" class="ab-cta-button">Guardar cambios</button>
      <p class="ab-muted-text" id="profile-feedback" aria-live="polite"></p>
    </form>

    <!-- Resumen en tarjeta -->
    <div class="ab-profile-data__card" id="profile-card"></div>

    <!-- Accesos a secciones relacionadas -->
    <div class="ab-actions">
      <a class="ab-cta-button" href="/mis-compras">Ver mis compras</a>
      <a class="ab-cta-button ab-sales-link" href="/mis-ventas">
        Ver mis ventas
        <span id="my-sales-notification-dot" class="ab-sales-notification-dot ab-is-hidden" aria-hidden="true"></span>
      </a>
      <a class="ab-cta-button" href="/mis-servicios">Ver mis servicios</a>
      <a class="ab-cta-button" href="/cuenta/profesional">Convertite en profesional</a>
    </div>
  </section>
</MainLayout>

<script type="module" src={profileScriptUrl}></script>
