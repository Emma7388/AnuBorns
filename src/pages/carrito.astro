---
// Página: carrito con listado y resumen.
import MainLayout from "../layouts/MainLayout.astro";
import cartScriptUrl from "../scripts/cart.js?url";
---

<MainLayout title="Carrito">
  <!-- Panel principal del carrito -->
  <section class="ab-dark-panel ab-cart-panel">
    <p class="ab-eyebrow">Carrito</p>
    <h1>Tu carrito</h1>
    <p class="ab-muted-text">
      Revisá tus productos antes de continuar al checkout.
    </p>

    <!-- Estado vacío -->
    <div id="cart-empty" class="ab-cart-empty">
      <p>No hay productos en el carrito.</p>
    </div>

    <!-- Items renderizados por JS -->
    <div id="cart-items" class="ab-cart-items" aria-live="polite"></div>

    <!-- Resumen y acciones -->
    <div class="ab-cart-summary">
      <p class="ab-cart-summary__total">
        Total: <strong id="cart-total">$0</strong>
      </p>
      <div class="ab-actions">
        <a class="ab-cta-button" href="/mis-compras">Ver mis compras</a>
        <button id="cart-checkout" class="ab-cta-button" type="button">
          Continuar a finalizar compra
        </button>
        <button id="cart-clear" type="button">Vaciar carrito</button>
      </div>
      <p id="cart-feedback" class="ab-muted-text" aria-live="polite"></p>
    </div>
  </section>

  <div
    id="cart-remove-modal"
    class="ab-orders-modal ab-is-hidden"
    role="dialog"
    aria-modal="true"
    aria-hidden="true"
    aria-labelledby="cart-remove-title"
  >
    <div class="ab-orders-modal__backdrop" data-cart-modal-close></div>
    <div class="ab-orders-modal__panel" role="document">
      <h2 id="cart-remove-title">Quitar producto</h2>
      <p>¿Seguro que querés quitar este producto del carrito?</p>
      <div class="ab-orders-modal__actions">
        <button type="button" class="ab-orders-delete-btn ab-orders-delete-btn--ghost" data-cart-modal-cancel>
          Cancelar
        </button>
        <button type="button" class="ab-orders-delete-btn" data-cart-modal-confirm>
          Sí, quitar
        </button>
      </div>
    </div>
  </div>
</MainLayout>

<!-- Script de interacción del carrito -->
<script type="module" src={cartScriptUrl}></script>
