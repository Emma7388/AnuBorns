---
import MainLayout from "../layouts/MainLayout.astro";
import loginScriptUrl from "../scripts/login.js?url";
---

<MainLayout title="Iniciar sesión">
  <section class="ab-dark-panel">
    <p class="ab-eyebrow">Acceso</p>
    <h1>Ingresá a tu cuenta</h1>
    <p class="ab-muted-text">Accedé con tu email y contraseña.</p>

    <form class="ab-form" id="login-form">
      <label for="email">Email</label>
      <input
        id="email"
        name="email"
        type="email"
        placeholder="tu@email.com"
        required
      />

      <label for="password">Contraseña</label>
      <input id="password" name="password" type="password" placeholder="••••••••" required />

      <div class="ab-actions">
        <button type="submit" class="ab-cta-button" id="login-submit">Ingresar</button>
      </div>
      <p id="login-feedback" class="ab-muted-text" aria-live="polite"></p>
    </form>
  </section>
</MainLayout>

<script type="module" src={loginScriptUrl}></script>
