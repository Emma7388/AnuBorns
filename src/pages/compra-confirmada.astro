---
import MainLayout from "../layouts/MainLayout.astro";
import confirmationScriptUrl from "../scripts/confirmation.js?url";
---

<MainLayout title="Compra confirmada">
  <section class="ab-dark-panel ab-confirmation-panel">
    <div class="ab-confirmation-card">
      <div class="ab-checkmark">
        <svg viewBox="0 0 52 52" aria-hidden="true">
          <circle class="ab-checkmark__circle" cx="26" cy="26" r="24" fill="none" />
          <path class="ab-checkmark__check" fill="none" d="M14 27l7 7 16-16" />
        </svg>
      </div>
      <h1 id="confirmation-title">Pago recibido</h1>
      <p class="ab-muted-text" id="confirmation-message">
        Estamos validando el estado de la compra.
      </p>
      <p class="ab-muted-text" id="confirmation-order"></p>
    </div>
  </section>
</MainLayout>

<script type="module" src={confirmationScriptUrl}></script>
