---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
---

<MainLayout title="Inicio">
  <section class="hero">
    <div class="hero-content">
      <h1>Comprá. Vendé. Ofertá.</h1>

      <div class="hero-buttons">
        <a href="/comprar/" class="ab-cta-button">
          Comprá
        </a>

        <a href="/vender/" class="ab-cta-button">
          Vendé
        </a>

        <a href="/oferta/" class="ab-cta-button">
          Ofertá
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    min-height: calc(100vh - 160px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0 20px;
  }

  .hero-content {
    max-width: 800px;
  }

  .hero h1 {
    font-size: 56px;
    margin-bottom: 50px;
    letter-spacing: -1px;
  }

  .hero-buttons {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
  }


  .hero-buttons .ab-cta-button {
    padding: 16px 40px;
    border-radius: 14px;
    transition: 0.25s ease;
  }

  .hero-buttons .ab-cta-button:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(22, 199, 132, 0.35);
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 38px;
    }
  }
</style>
