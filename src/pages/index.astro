---
// Página de inicio con accesos principales.
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
---

<MainLayout title="Inicio">
  <!-- Hero principal -->
  <section class="hero">
    <div class="hero-content">
      <!-- Mensaje central -->
      <h1>Comprá. Vendé. Ofertá.</h1>

      <!-- CTAs principales -->
      <div class="hero-buttons">
        <a href="/comprar/" class="ab-cta-button">
          Comprá
        </a>

        <a href="/vender/" class="ab-cta-button">
          Vendé
        </a>

        <a href="/oferta/" class="ab-cta-button">
          Ofertá
        </a>
      </div>
    </div>
  </section>
</MainLayout>
