---
import MainLayout from "../layouts/MainLayout.astro";
import registerScriptUrl from "../scripts/register.js?url";
---

<MainLayout title="Crear cuenta">
  <section class="ab-dark-panel">
    <p class="ab-eyebrow">Registro</p>
    <h1>Creá tu cuenta</h1>
    <p class="ab-muted-text">Registrate con tu email y contraseña.</p>

    <form class="ab-form" id="register-form">
      <label for="avatar">Avatar (opcional)</label>
      <input id="avatar" name="avatar" type="file" accept="image/*" />

      <label for="first-name">Nombre</label>
      <input id="first-name" name="first-name" type="text" placeholder="Ej: María" />

      <label for="last-name">Apellido</label>
      <input id="last-name" name="last-name" type="text" placeholder="Ej: López" />

      <label for="email">Email</label>
      <input id="email" name="email" type="email" placeholder="tu@email.com" required />

      <label for="phone">Teléfono</label>
      <input id="phone" name="phone" type="tel" placeholder="Ej: 11 2345 6789" />

      <label for="dni">DNI</label>
      <input id="dni" name="dni" type="text" placeholder="Ej: 12345678" />

      <label for="address">Dirección</label>
      <input id="address" name="address" type="text" placeholder="Ej: Av. Siempre Viva 742" />

      <label for="city">Ciudad</label>
      <input id="city" name="city" type="text" placeholder="Ej: Buenos Aires" />

      <label for="province">Provincia</label>
      <input id="province" name="province" type="text" placeholder="Ej: Buenos Aires" />

      <label for="postal-code">Código postal</label>
      <input id="postal-code" name="postal-code" type="text" placeholder="Ej: B1675" />

      <label for="password">Contraseña</label>
      <input id="password" name="password" type="password" placeholder="••••••••" minlength="6" required />

      <label for="password-confirm">Confirmar contraseña</label>
      <input
        id="password-confirm"
        name="password-confirm"
        type="password"
        placeholder="••••••••"
        minlength="6"
        required
      />

      <button type="submit" class="ab-cta-button">Crear cuenta</button>
      <p id="register-feedback" class="ab-muted-text" aria-live="polite"></p>
    </form>
  </section>
</MainLayout>

<script type="module" src={registerScriptUrl}></script>
