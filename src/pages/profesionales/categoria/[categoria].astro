---
// Página: listado de profesionales por categoría.
import MainLayout from "../../../layouts/MainLayout.astro";
import { categories } from "../../../data/categories";
import { providers } from "../../../data/providers";
import ProviderCard from "../../../components/ProviderCard.astro";
import "../../../styles/global.css";

// Rutas estáticas por categoría.
export async function getStaticPaths() {
  return categories.map((cat) => ({
    params: { categoria: cat.slug }
  }));
}

// Datos filtrados y ordenados por ranking.
const { categoria } = Astro.params;
const currentCategory = categories.find((cat) => cat.slug === categoria);
const categoryProviders = providers
  .filter((provider) => provider.category === categoria)
  .sort((a, b) => {
    const avgDelta = (a.average ?? 0) - (b.average ?? 0);
    if (avgDelta !== 0) return avgDelta;
    return (b.reviews ?? 0) - (a.reviews ?? 0);
  });
---

<MainLayout title={`Profesionales en ${currentCategory?.name || categoria}`}>
  <!-- Panel de listado -->
  <section class="ab-dark-panel ab-list-panel">
    <p class="ab-eyebrow">Búsqueda por categoría</p>
    <h1>{currentCategory?.name || categoria}</h1>
    <p class="ab-muted-text">
      Mostrando {categoryProviders.length} profesionales disponibles.
    </p>

    <!-- Grilla de tarjetas -->
    <div class="ab-card-grid">
      {categoryProviders.map((provider, index) => (
        <ProviderCard
          name={provider.name}
          ranking={index + 1}
          average={provider.average}
          location={provider.location}
          avatar={provider.avatar}
          dailySold={provider.dailySold}
          sponsor={provider.sponsor}
          category={provider.category}
          slug={provider.slug}
          profileBasePath="/profesionales"
          productsBasePath="/profesionales"
          fromPath={`/profesionales/categoria/${categoria}`}
        />
      ))}
    </div>
  </section>
</MainLayout>
