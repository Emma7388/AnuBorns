---
import MainLayout from "../../../layouts/MainLayout.astro";
import { providers } from "../../../data/providers";
import { categories } from "../../../data/categories";

export async function getStaticPaths() {
  return providers.map((provider) => ({
    params: { slug: provider.slug }
  }));
}

const { slug } = Astro.params;
const provider = providers.find((item) => item.slug === slug);
const categoryName = categories.find((item) => item.slug === provider?.category)?.name;
const products = provider?.products ?? [];
const fromParam = Astro.url.searchParams.get("from");
const backHref = fromParam && fromParam.startsWith("/")
  ? fromParam
  : provider
    ? `/profesionales/categoria/${provider.category}`
    : "/profesionales";
---

<MainLayout title={provider ? `Productos de ${provider.name}` : "Productos del profesional"} backHref={backHref}>
  {provider ? (
    <section class="ab-dark-panel ab-provider-products-panel">
      <p class="ab-eyebrow">Catálogo del profesional</p>
      <h1>{provider.name}</h1>
      <p class="ab-muted-text">
        Categoría: <strong>{categoryName ?? provider.category}</strong> · {provider.location}
      </p>

      {products.length > 0 ? (
        <div class="ab-provider-products-grid">
          {products.map((product) => (
            <article class="ab-provider-product-card">
              <img
                class="ab-provider-product-card__image"
                src={product.image ?? "/logo2.svg"}
                alt={product.name}
                loading="lazy"
              />
              <div class="ab-provider-product-card__header">
                <p class="ab-provider-product-card__sku">SKU: {product.sku ?? "N/A"}</p>
              </div>
              <h2>{product.name}</h2>
              <p class="ab-provider-product-card__description">{product.description}</p>
              <p class="ab-provider-product-card__price">
                ${product.price.toLocaleString("es-AR")} <span>/ {product.unit}</span>
              </p>
              <div class="ab-provider-product-card__actions">
                <button type="button" class="ab-provider-product-card__button ab-provider-product-card__button--ghost">
                  Consultar
                </button>
                <button type="button" class="ab-provider-product-card__button ab-provider-product-card__button--buy">
                  Comprar
                </button>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p>Este profesional todavía no publicó productos.</p>
      )}

      <div class="ab-provider-profile__actions">
        <a href={`/profesionales/${provider.slug}?from=${encodeURIComponent(backHref)}`} class="ab-back-link">Ver perfil</a>
      </div>
    </section>
  ) : (
    <section class="ab-dark-panel">
      <h1>Profesional no encontrado</h1>
      <p>No se puede mostrar el catálogo porque el profesional no existe.</p>
      <a href="/profesionales" class="ab-back-link">Ir a profesionales</a>
    </section>
  )}
</MainLayout>
