---
// Página: historial de servicios.
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Mis servicios" backHref="/mis-datos">
  <section class="ab-dark-panel ab-services-panel">
    <p class="ab-eyebrow">Usuario base</p>
    <h1>Mis servicios</h1>
    <p class="ab-muted-text">
      Historial de servicios finalizados y el servicio activo primero.
    </p>
    <div id="service-active"></div>

    <div id="services-empty" class="ab-cart-empty ab-is-hidden">
      <p>Todavía no registraste servicios.</p>
    </div>

    <h2 id="service-history-title">Servicios finalizados</h2>
    <div class="ab-actions">
      <button id="services-reset" type="button">Resetear datos</button>
    </div>
    <div id="service-list" class="ab-service-list"></div>
  </section>
</MainLayout>

<script>
  import "../scripts/mis-servicios.js";
</script>
