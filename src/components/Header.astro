---
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">Desoluciones</a>

    <nav class="nav">
      <div class="nav-auth nav-auth--user">
        <a class="nav-avatar" href="/mis-datos" aria-label="Ir a perfil">
          <span>U</span>
        </a>
        <a class="nav-cart" href="/carrito" aria-label="Ir al carrito">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M7 18c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1Zm10 0c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1ZM6.24 6h12.88c.45 0 .84.3.96.74l1.6 6.1a1 1 0 0 1-.96 1.26H8.02a1 1 0 0 1-.96-.74L5.15 5H3.5a1 1 0 1 1 0-2h2.15c.46 0 .86.3.97.74L6.24 6Z"
            />
          </svg>
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
.header {
  background: var(--color-surface);
  color: var(--color-text);
  padding: 1rem 0;
  border-bottom: 1px solid var(--color-border-subtle);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  min-height: var(--header-height);
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 50;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
}

.logo {
  font-weight: bold;
  font-size: 1.3rem;
  text-decoration: none;
  color: var(--color-text);
}

.nav-auth {
  display: flex;
  align-items: center;
}

.nav-auth--user {
  gap: 12px;
}

.nav-avatar {
  width: 40px;
  height: 40px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--color-accent);
  color: var(--color-surface);
  font-weight: 700;
  text-decoration: none;
  box-shadow: 0 10px 20px rgba(22, 199, 132, 0.2);
}

.nav-avatar span {
  font-size: 0.95rem;
}

.nav-cart {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  border: 1px solid var(--color-border-subtle);
  background: rgba(255, 255, 255, 0.04);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  color: var(--color-text);
}

.nav-cart svg {
  width: 22px;
  height: 22px;
  fill: currentColor;
}

.nav-cart:hover {
  background: rgba(255, 255, 255, 0.08);
}

@media (max-width: 380px) {
  .nav {
    display: flex;
    align-items: center;
  }

  .nav-auth--user {
    gap: 8px;
  }

  .nav-avatar {
    width: 34px;
    height: 34px;
  }

  .nav-cart {
    width: 38px;
    height: 38px;
  }
}

</style>
