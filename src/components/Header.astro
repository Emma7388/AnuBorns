---
import headerAuthUrl from "../scripts/header-auth.js?url";
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">Desoluciones</a>

    <nav class="nav">
      <div class="nav-auth nav-auth--guest ab-is-hidden" data-auth="guest">
        <a class="nav-login" href="/login">Iniciar sesión</a>
        <a class="nav-login nav-login--ghost" href="/registro">Registrarse</a>
      </div>
      <div class="nav-auth nav-auth--user ab-is-hidden" data-auth="user">
        <a class="nav-avatar" href="/mis-datos" aria-label="Ir a mis datos">
          <img id="auth-avatar" alt="Avatar de usuario" />
        </a>
        <button class="nav-login nav-login--ghost" type="button" id="auth-logout">Salir</button>
      </div>
    </nav>
  </div>
</header>

<style>
.header {
  background: var(--color-surface);
  color: var(--color-text);
  padding: 1rem 0;
  border-bottom: 1px solid var(--color-border-subtle);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  min-height: var(--header-height);
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 50;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.logo {
  font-weight: bold;
  font-size: 1.3rem;
  text-decoration: none;
  color: var(--color-text);
  letter-spacing: 0.3px;
}

.nav {
  display: flex;
  align-items: center;
}

.nav-auth {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.nav-auth--guest {
  gap: 10px;
}

.nav-auth--user {
  gap: 10px;
}

.nav-login {
  padding: 0.6rem 1.2rem;
  border-radius: 999px;
  background: var(--color-accent);
  color: var(--color-on-accent);
  font-weight: 700;
  text-decoration: none;
  border: none;
  cursor: pointer;
  font: inherit;
  white-space: nowrap;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  box-shadow: 0 10px 20px rgba(22, 199, 132, 0.25);
}

.nav-login:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 24px rgba(22, 199, 132, 0.3);
}

.nav-login--ghost {
  background: transparent;
  border: 1px solid var(--color-border-subtle);
  color: var(--color-text);
  font-weight: 600;
  box-shadow: none;
}

.nav-login--ghost:hover {
  color: var(--color-text);
  border-color: var(--color-accent);
  transform: translateY(-1px);
}

.nav-user {
  font-weight: 600;
  color: var(--color-text);
  padding: 0.4rem 0.8rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.nav-avatar {
  width: 36px;
  height: 36px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.06);
  display: grid;
  place-items: center;
  overflow: hidden;
}

.nav-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: none;
}

@media (max-width: 380px) {
  .nav {
    display: flex;
    align-items: center;
  }

  .nav-auth--guest {
    gap: 8px;
  }
}

@media (max-width: 520px) {
  .header-inner {
    flex-direction: column;
    align-items: flex-start;
  }

  .nav-auth {
    width: 100%;
    justify-content: flex-start;
  }

  .nav-login,
  .nav-login--ghost {
    padding: 0.55rem 1rem;
    font-size: 0.95rem;
  }
}

@media (max-width: 720px) {
  .nav-auth--user {
    width: 100%;
  }
}
</style>

<script type="module" src={headerAuthUrl}></script>
