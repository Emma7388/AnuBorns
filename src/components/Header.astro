---
import headerAuthUrl from "../scripts/header-auth.js?url";
---

<header class="header" transition:persist>
  <div class="container header-inner">
    <a href="/" class="logo">Desoluciones</a>

    <nav class="nav">
      <div class="nav-auth nav-auth--guest ab-is-hidden" data-auth="guest">
        <a class="nav-login" href="/login">Iniciar sesión</a>
        <a class="nav-login nav-login--ghost" href="/registro">Registrarse</a>
      </div>
      <div class="nav-auth nav-auth--user ab-is-hidden" data-auth="user">
        <span class="nav-user nav-user--plain" id="auth-name"></span>
        <a
          class="nav-avatar"
          href="/mis-datos"
          aria-label="Ir a mis datos"
          data-astro-reload
          data-ab-profile-link
        >
          <img id="auth-avatar" alt="Avatar de usuario" />
        </a>
        <button class="nav-login nav-login--ghost" type="button" id="auth-logout">Salir</button>
      </div>
    </nav>
  </div>
</header>

<div class="ab-modal ab-is-hidden" id="logout-modal" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="ab-modal__backdrop" data-modal-close></div>
  <div class="ab-modal__panel" role="document" aria-labelledby="logout-title">
    <h2 id="logout-title">Cerrar sesión</h2>
    <p>¿Estás seguro de que querés cerrar sesión?</p>
    <div class="ab-modal__actions">
      <button type="button" class="nav-login nav-login--ghost" data-modal-cancel>
        Cancelar
      </button>
      <button type="button" class="nav-login" data-modal-confirm>
        Sí, salir
      </button>
    </div>
  </div>
</div>

<style>
.header {
  background: var(--color-surface);
  color: var(--color-text);
  padding: 1rem 0;
  border-bottom: 1px solid var(--color-border-subtle);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  min-height: var(--header-height);
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 50;
}

.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.logo {
  font-weight: bold;
  font-size: 1.3rem;
  text-decoration: none;
  color: var(--color-text);
  letter-spacing: 0.3px;
}

.nav {
  display: flex;
  align-items: center;
}

.nav-auth {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.nav-auth--guest {
  gap: 10px;
}

.nav-auth--user {
  gap: 10px;
}

.nav-login {
  padding: 0.6rem 1.2rem;
  border-radius: 999px;
  background: var(--color-accent);
  color: var(--color-on-accent);
  font-weight: 700;
  text-decoration: none;
  border: none;
  cursor: pointer;
  font: inherit;
  white-space: nowrap;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  box-shadow: 0 10px 20px rgba(22, 199, 132, 0.25);
}

.nav-login:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 24px rgba(22, 199, 132, 0.3);
}

.nav-login--ghost {
  background: transparent;
  border: 1px solid var(--color-border-subtle);
  color: var(--color-text);
  font-weight: 600;
  box-shadow: none;
}

.nav-login--ghost:hover {
  color: var(--color-text);
  border-color: var(--color-accent);
  transform: translateY(-1px);
}

.nav-user {
  font-weight: 600;
  color: var(--color-text);
  padding: 0.4rem 0.8rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.nav-user--plain {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
}

.ab-modal {
  position: fixed;
  inset: 0;
  display: grid;
  place-items: center;
  z-index: 120;
}

.ab-modal:not(.ab-is-hidden) {
  animation: ab-modal-fade 0.18s ease;
}

.ab-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(5, 8, 12, 0.7);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.ab-modal__panel {
  position: relative;
  z-index: 1;
  width: min(92vw, 420px);
  padding: 20px;
  border-radius: 16px;
  border: 1px solid var(--color-border-subtle);
  background: var(--color-surface);
  color: var(--color-text);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
  display: grid;
  gap: 12px;
}

.ab-modal:not(.ab-is-hidden) .ab-modal__panel {
  animation: ab-modal-pop 0.2s ease;
}

.ab-modal__panel h2 {
  margin: 0;
  text-align: left;
}

.ab-modal__panel p {
  margin: 0;
  color: var(--color-text-muted);
}

.ab-modal__actions {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
  flex-wrap: wrap;
}

@keyframes ab-modal-fade {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes ab-modal-pop {
  from {
    transform: translateY(6px);
    opacity: 0.9;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@media (prefers-reduced-motion: reduce) {
  .ab-modal:not(.ab-is-hidden),
  .ab-modal:not(.ab-is-hidden) .ab-modal__panel {
    animation: none;
  }
}

.nav-avatar {
  width: 36px;
  height: 36px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.06);
  display: grid;
  place-items: center;
  overflow: hidden;
}

.nav-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: none;
}

@media (max-width: 380px) {
  .nav {
    display: flex;
    align-items: center;
  }

  .nav-auth--guest {
    gap: 8px;
  }
}

@media (max-width: 520px) {
  .header-inner {
    flex-direction: column;
    align-items: flex-start;
  }

  .nav-auth {
    width: 100%;
    justify-content: flex-start;
  }

  .nav-login,
  .nav-login--ghost {
    padding: 0.55rem 1rem;
    font-size: 0.95rem;
  }
}

@media (max-width: 720px) {
  .nav-auth--user {
    width: 100%;
  }
}
</style>

<script type="module" src={headerAuthUrl}></script>
