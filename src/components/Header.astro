---
// Componente: header con auth, carrito y modal de logout.
import headerAuthUrl from "../scripts/header-auth.js?url";
---

<header class="header" transition:persist>
  <div class="container header-inner">
    <!-- Marca / logo -->
    <a href="/" class="logo">Desoluciones</a>

    <!-- Título de página (inyectado desde MainLayout) -->
    <div id="ab-header-page-title" class="ab-header-page-title" aria-live="polite"></div>

    <!-- Navegación superior -->
    <nav class="nav">
      <!-- Acceso rápido al carrito -->
      <a class="nav-cart" href="/carrito" aria-label="Ir al carrito">
        Carrito <span id="cart-count">0</span>
      </a>
      <span id="cart-sync" class="nav-cart-sync ab-is-hidden">Sincronizando</span>
      <!-- Estado: usuario invitado -->
      <div class="nav-auth nav-auth--guest ab-is-hidden" data-auth="guest">
        <a class="nav-login" href="/login">Iniciar sesión</a>
        <a class="nav-login nav-login--ghost" href="/registro">Registrarse</a>
      </div>
      <!-- Estado: usuario autenticado -->
      <div class="nav-auth nav-auth--user ab-is-hidden" data-auth="user">
        <span class="nav-user nav-user--plain" id="auth-name"></span>
        <a
          class="nav-avatar"
          href="/mis-datos"
          aria-label="Ir a mis datos"
          data-astro-reload
          data-ab-profile-link
        >
          <span id="sales-notification-dot" class="ab-sales-notification-dot ab-is-hidden" aria-hidden="true"></span>
          <img id="auth-avatar" alt="Avatar de usuario" />
        </a>
        <button class="nav-login nav-login--ghost" type="button" id="auth-logout">Salir</button>
      </div>
    </nav>
  </div>
</header>

<!-- Modal de confirmación para cerrar sesión -->
<div class="ab-modal ab-is-hidden" id="logout-modal" role="dialog" aria-modal="true" aria-hidden="true">
  <div class="ab-modal__backdrop" data-modal-close></div>
  <div class="ab-modal__panel" role="document" aria-labelledby="logout-title">
    <h2 id="logout-title">Cerrar sesión</h2>
    <p>¿Estás seguro de que querés cerrar sesión?</p>
    <div class="ab-modal__actions">
      <button type="button" class="nav-login nav-login--ghost" data-modal-cancel>
        Cancelar
      </button>
      <button type="button" class="nav-login" data-modal-confirm>
        Sí, salir
      </button>
    </div>
  </div>
</div>

<style>
/* Layout general del header */
.header {
  background: var(--color-surface);
  color: var(--color-text);
  padding: 1rem 0;
  border-bottom: 1px solid var(--color-border-subtle);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  min-height: var(--header-height);
  display: flex;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 50;
}

.header-inner {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.ab-header-page-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  max-width: min(52vw, 640px);
  text-align: center;
  width: 100%;
  pointer-events: none;
  z-index: 1;
}

.ab-header-page-title:empty {
  display: none;
}

.ab-header-page-title h1 {
  margin: 0;
  font-size: clamp(1rem, 2.2vw, 1.4rem);
  font-weight: 800;
  color: var(--color-text);
  line-height: 1.2;
  text-wrap: balance;
}

.logo {
  font-weight: bold;
  font-size: 1.3rem;
  text-decoration: none;
  color: var(--color-text);
  letter-spacing: 0.3px;
}

.nav {
  display: flex;
  align-items: center;
  gap: 10px;
}

.nav-auth {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  justify-content: flex-end;
}

.nav-auth--guest {
  gap: 10px;
}

.nav-auth--user {
  gap: 10px;
}

.nav-login {
  padding: 0.6rem 1.2rem;
  border-radius: 999px;
  background: var(--color-accent);
  color: var(--color-on-accent);
  font-weight: 700;
  text-decoration: none;
  border: none;
  cursor: pointer;
  font: inherit;
  white-space: nowrap;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  box-shadow: 0 10px 20px rgba(22, 199, 132, 0.25);
}

.nav-login:hover {
  box-shadow: 0 14px 24px rgba(22, 199, 132, 0.3);
}

.nav-login:active {
  transform: translateY(1px);
}

.nav-login--ghost {
  background: transparent;
  border: 1px solid var(--color-border-subtle);
  color: var(--color-text);
  font-weight: 600;
  box-shadow: none;
}

.nav-login--ghost:hover {
  color: var(--color-text);
  border-color: var(--color-accent);
}

.nav-login--ghost:active {
  transform: translateY(1px);
}

.nav-user {
  font-weight: 600;
  color: var(--color-text);
  padding: 0.4rem 0.8rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.nav-user--plain {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
}

/* Modal: estilos y animaciones */
.ab-modal {
  position: fixed;
  inset: 0;
  display: grid;
  place-items: center;
  z-index: 120;
}

.ab-modal:not(.ab-is-hidden) {
  animation: ab-modal-fade 0.18s ease;
}

.ab-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(5, 8, 12, 0.7);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.ab-modal__panel {
  position: relative;
  z-index: 1;
  width: min(92vw, 420px);
  padding: 20px;
  border-radius: 16px;
  border: 1px solid var(--color-border-subtle);
  background: var(--color-surface);
  color: var(--color-text);
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.35);
  display: grid;
  gap: 12px;
}

.ab-modal:not(.ab-is-hidden) .ab-modal__panel {
  animation: ab-modal-pop 0.2s ease;
}

.ab-modal__panel h2 {
  margin: 0;
  text-align: left;
}

.ab-modal__panel p {
  margin: 0;
  color: var(--color-text-muted);
}

.ab-modal__actions {
  display: flex;
  gap: 10px;
  justify-content: flex-end;
  flex-wrap: wrap;
}

@keyframes ab-modal-fade {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes ab-modal-pop {
  from {
    transform: translateY(6px);
    opacity: 0.9;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@media (prefers-reduced-motion: reduce) {
  .ab-modal:not(.ab-is-hidden),
  .ab-modal:not(.ab-is-hidden) .ab-modal__panel {
    animation: none;
  }
}

/* Avatar de usuario */
.nav-avatar {
  position: relative;
  width: 36px;
  height: 36px;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.06);
  display: grid;
  place-items: center;
  overflow: visible;
}

.ab-sales-notification-dot {
  position: absolute;
  top: -2px;
  right: -2px;
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: #22c55e;
  border: 2px solid var(--color-bg);
  box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.25);
  z-index: 2;
}

.nav-cart {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 0.55rem 1rem;
  border-radius: 999px;
  border: 1px solid var(--glass-green-border);
  background: var(--glass-green-bg);
  color: var(--color-text);
  font-weight: 700;
  text-decoration: none;
  font-size: 0.95rem;
}

.nav-cart span {
  background: var(--color-accent);
  color: var(--color-on-accent);
  border-radius: 999px;
  padding: 2px 8px;
  font-size: 12px;
}

.nav-cart-sync {
  font-size: 11px;
  color: var(--color-text);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid var(--color-border-subtle);
  border-radius: 999px;
  padding: 4px 8px;
}

.nav-avatar img {
  width: 100%;
  height: 100%;
  border-radius: 999px;
  object-fit: cover;
  display: none;
}

/* Responsive: ajustes de layout */
@media (max-width: 380px) {
  .nav {
    display: flex;
    align-items: center;
  }

  .nav-auth--guest {
    gap: 8px;
  }
}

@media (max-width: 520px) {
  .header-inner {
    position: static;
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .logo,
  .ab-header-page-title,
  .nav-auth {
    width: 100%;
  }

  .ab-header-page-title {
    position: static;
    transform: none;
    max-width: none;
  }

  .ab-header-page-title h1 {
    font-size: clamp(1rem, 5.2vw, 1.25rem);
  }

  .nav {
    width: 100%;
    justify-content: space-between;
    flex-wrap: wrap;
  }

  .nav-auth {
    justify-content: flex-start;
  }

  .nav-login,
  .nav-login--ghost {
    padding: 0.55rem 1rem;
    font-size: 0.95rem;
  }
}

@media (max-width: 720px) {
  .nav-auth--user {
    width: 100%;
  }
}
</style>

<script type="module" src={headerAuthUrl}></script>
