---
const { name, role, rating, jobs, image } = Astro.props;
---

<div class="card">
  <img src={image} alt={name} class="card-image" />
  <div class="card-content">
    <h3>{name}</h3>
    <p class="role">{role}</p>
    <div class="meta">
      <span>⭐ {rating}</span>
      <span>{jobs} trabajos</span>
    </div>
  </div>
</div>

<style>
.card {
  width: 300px;
  border-radius: 18px;
  overflow: hidden;
  background: white;
  cursor: pointer;
  padding:5px;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  border: 1px solid rgba(0, 0, 0, 0.05);
}

.card:hover {
  transform: translateY(-6px);
  box-shadow: 0 14px 28px rgba(0, 0, 0, 0.15);
}
.card-image {
  width: 100%;
  height: 200px;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.card:hover .card-image {
  transform: scale(1.05);
}

.card-content h3 {
  font-size: 18px;
  font-weight: 600;
  margin: 0;
}

.role {
  color: #777;
  font-size: 14px;
  margin: 0;
}

.meta {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  color: #555;
}
</style>