---
const {
  name,
  ranking,
  average,
  location,
  sponsor = false,
  category,
  slug,
} = Astro.props
---
<div class="ab-provider-card">
  {ranking <= 3 && (
    <div class="ab-provider-card__ranking-badge">
      ⭐ Ranking #{ranking}
    </div>
  )}

  {sponsor && <div class="ab-provider-card__sponsor-badge">SPONSOR</div>}

  <h2 class="ab-provider-card__name">{name}</h2>

  <p class="ab-provider-card__average">
    Promedio publicado: <strong>${average}</strong>
  </p>

  <p class="ab-provider-card__location">{location}</p>

  <a
    href={`/proveedor/${slug}/productos?from=${encodeURIComponent(`/comprar/productos/${category}`)}`}
    class="ab-cta-button"
  >
    Ver productos
  </a>
  <a href={`/proveedor/${slug}?from=${encodeURIComponent(`/comprar/productos/${category}`)}`} class="ab-cta-button">Ver perfil</a>

</div>
