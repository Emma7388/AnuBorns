---
const {
  name,
  ranking,
  average,
  location,
  sponsor = false,

  slug,
} = Astro.props
---
<div class="provider-card">
  {ranking <= 3 && (
    <div class="ab-provider-card__ranking-badge">
      ⭐ Ranking #{ranking}
    </div>
  )}

  {sponsor && <div class="ab-provider-card__sponsor-badge">SPONSOR</div>}

  <h2 class="ab-provider-card__name">{name}</h2>

  <p class="ab-provider-card__average">
    Promedio publicado: <strong>${average}</strong>
  </p>

  <p class="ab-provider-card__location">{location}</p>

  <a href={`/proveedor/${slug}`} class="ab-cta-button">Ver perfil</a>

  {sponsor && (
    <div class="sponsor-badge">
      SPONSOR
    </div>
  )}
  <h2 class="provider-name">{name}</h2>
  <p class="average">
    Promedio 10 productos: <strong>${average}</strong>
  </p>
  <p class="location">{location}</p>
  <button class="view-btn">Ver productos</button>
  <a href={`/proveedor/${slug}`} class="view-btn">Ver perfíl</a>

</div>
