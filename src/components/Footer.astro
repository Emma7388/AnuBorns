---
// Componente: footer con CTA opcional de regreso.
const { showBack = false, backHref = "/" } = Astro.props;
const useHistoryBack = backHref === "history";
const resolvedBackHref = useHistoryBack ? "/" : backHref;
---

<!-- Pie de página principal -->
<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <p>© 2026 Desoluciones. Todos los derechos reservados.</p>
      <!-- Botón volver opcional -->
      {showBack && (
        <a
          class="ab-cta-button footer-back"
          href={resolvedBackHref}
          data-ab-back={useHistoryBack ? "history" : "link"}
          {...(backHref === "/mis-datos" ? { "data-astro-reload": true } : {})}
        >
          Volver
        </a>
      )}
    </div>
  </div>
</footer>

<style>
/* Layout y estilo del footer */
.footer {
  background: var(--color-surface);
  color: var(--color-text-muted);
  padding: 0;
  margin-top: 0;
  text-align: center;
  border-top: 1px solid var(--color-border-subtle);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  min-height: var(--footer-height);
  display: flex;
  align-items: center;
  position: sticky;
  bottom: 0;
  z-index: 40;
}

.footer-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  width: 100%;
}

.footer-back {
  white-space: nowrap;
}

/* Ajustes responsive */
@media (max-width: 1024px) {
  .footer {
    position: static;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    background: var(--color-bg);
  }
}

@media (max-width: 720px) {
  .footer-content {
    flex-direction: column;
    text-align: center;
  }
}
</style>
